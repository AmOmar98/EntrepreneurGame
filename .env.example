# Supabase - Public client (browser + server SSR)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# Supabase - Service role (server actions only - magic link invites)
# SECURITY: never expose to client. Set in Vercel as Secret env var (Production only).
# Required for /admin/players/import to send magic-link invites via inviteUserByEmail.
# When absent, the import still creates Players + links existing users; missing
# users are reported as "service role missing - invite skipped".
SUPABASE_SERVICE_ROLE_KEY=replace-me

# App - public URL used for magic-link redirects and email body links
# Local dev: http://localhost:3000
# Vercel preview: auto-set per deployment
# Production: https://entrepreneur-game-six.vercel.app (pilot, slug auto-suffixed by Vercel; custom EIC domain TBD)
NEXT_PUBLIC_APP_URL=https://entrepreneur-game-six.vercel.app
